{
  "name": "@kvoon/cg",
  "version": "0.0.0",
  "private": true,
  "description": "a AI-powered git commit message generator",
  "files": [
    "dist"
  ],
  "type": "module",
  "bin": {
    "cg": "./dist/run.mjs"
  },
  "exports": {
    ".": "./dist/index.mjs",
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "lint": "oxlint --type-aware",
    "fmt": "oxfmt",
    "typecheck": "tsc --noEmit",
    "run": "node ./src/run.ts"
  },
  "devDependencies": {
    "@types/node": "^25.2.1",
    "@typescript-eslint/utils": "^8.54.0",
    "eslint-plugin-antfu": "^3.1.3",
    "oxfmt": "^0.36.0",
    "oxlint": "^1.51.0",
    "oxlint-tsgolint": "^0.16.0",
    "tsdown": "^0.21.3",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "@clack/prompts": "^0.11.0",
    "@mariozechner/pi-agent-core": "^0.58.4",
    "@mariozechner/pi-ai": "^0.58.4",
    "cac": "^7.0.0"
  }
}
