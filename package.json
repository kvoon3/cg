{
  "name": "commitgen",
  "version": "0.0.0",
  "private": true,
  "description": "A simple example library built by tsdown",
  "files": [
    "dist"
  ],
  "type": "module",
  "exports": {
    ".": "./dist/index.mjs",
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "lint": "oxlint --type-aware --tsconfig tsconfig.json",
    "fmt": "oxfmt"
  },
  "devDependencies": {
    "oxfmt": "^0.36.0",
    "oxlint": "^1.51.0",
    "oxlint-tsgolint": "^0.16.0",
    "tsdown": "^0.21.3",
    "typescript": "^5.9.3"
  }
}
