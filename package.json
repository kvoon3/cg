{
  "name": "@kvoon/cg",
  "version": "0.0.6",
  "description": "AI-powered git commit message generator",
  "keywords": [
    "ai",
    "clack",
    "commit",
    "conventional-commits",
    "git"
  ],
  "homepage": "https://github.com/kvoon3/cg#readme",
  "bugs": {
    "url": "https://github.com/kvoon3/cg/issues"
  },
  "license": "MIT",
  "author": "kvoon",
  "repository": {
    "type": "git",
    "url": "https://github.com/kvoon3/cg"
  },
  "bin": {
    "cg": "./dist/run.mjs"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "exports": {
    ".": "./dist/index.mjs",
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "lint": "oxlint --type-aware",
    "lint:fix": "oxlint --type-aware --fix",
    "fmt": "oxfmt",
    "typecheck": "tsc --noEmit",
    "cg": "node ./src/run.ts",
    "up": "npx taze -I major",
    "release": "npx bumpp && pnpm publish",
    "prepare": "simple-git-hooks"
  },
  "dependencies": {
    "@clack/prompts": "^0.11.0",
    "@mariozechner/pi-agent-core": "^0.58.4",
    "@mariozechner/pi-ai": "^0.58.4",
    "cac": "^7.0.0",
    "npmx-connector": "^0.4.0"
  },
  "devDependencies": {
    "@types/node": "^25.2.1",
    "@typescript-eslint/utils": "^8.54.0",
    "eslint-plugin-antfu": "^3.1.3",
    "lint-staged": "^16.3.2",
    "oxfmt": "^0.36.0",
    "oxlint": "^1.51.0",
    "oxlint-tsgolint": "^0.16.0",
    "simple-git-hooks": "^2.13.1",
    "tinyexec": "^1.0.4",
    "tsdown": "^0.21.3",
    "typescript": "^5.9.3"
  },
  "simple-git-hooks": {
    "pre-commit": "pnpm exec lint-staged"
  },
  "lint-staged": {
    "*": [
      "pnpm run fmt",
      "pnpm run lint:fix"
    ]
  },
  "inlinedDependencies": {
    "tinyexec": "1.0.4"
  }
}
